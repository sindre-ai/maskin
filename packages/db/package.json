{
	"name": "@maskin/db",
	"version": "0.0.1",
	"private": true,
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./schema": {
			"types": "./src/schema.ts",
			"default": "./dist/schema.js"
		},
		"./connection": {
			"types": "./src/connection.ts",
			"default": "./dist/connection.js"
		}
	},
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx src/migrate.ts",
		"db:seed": "tsx src/seed.ts",
		"build": "tsc",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@maskin/shared": "workspace:*",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.19.0",
		"typescript": "^6.0.3"
	}
}
