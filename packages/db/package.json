{
	"name": "@maskin/db",
	"version": "0.0.1",
	"private": true,
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./schema": {
			"types": "./src/schema.ts",
			"default": "./dist/schema.js"
		},
		"./connection": {
			"types": "./src/connection.ts",
			"default": "./dist/connection.js"
		}
	},
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"db:migrate": "node --env-file=../../.env --import tsx/esm src/migrate.ts",
		"db:seed": "node --env-file=../../.env --import tsx/esm src/seed.ts",
		"build": "tsc",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"bcryptjs": "^2.4.3",
		"drizzle-orm": "^0.38.0",
		"postgres": "^3.4.0"
	},
	"devDependencies": {
		"drizzle-kit": "^0.30.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0"
	}
}
