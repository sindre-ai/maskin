DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maskin
# Optional: overrides DATABASE_URL
# POSTGRES_URL=
# Optional: direct (non-pooled) connection for PG LISTEN/NOTIFY when using a connection pooler
# DATABASE_URL_DIRECT=

# Integration secrets encryption key (32-byte hex, 64 chars).
# Auto-generated by `pnpm dev` / `pnpm dev:win` if missing. Required to encrypt stored OAuth tokens.
INTEGRATION_ENCRYPTION_KEY=

# GitHub Integration
GITHUB_APP_ID
GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET
GITHUB_APP_WEBHOOK_SECRET
GITHUB_APP_PRIVATE_KEY
GITHUB_APP_SLUG
WEBHOOK_BASE_URL

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Linear Integration
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=
