DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_native_oss
# Optional: overrides DATABASE_URL
# POSTGRES_URL=
# Optional: direct (non-pooled) connection for PG LISTEN/NOTIFY when using a connection pooler
# DATABASE_URL_DIRECT=
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000

# GitHub Integration
INTEGRATION_ENCRYPTION_KEY
GITHUB_APP_ID
GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET
GITHUB_APP_WEBHOOK_SECRET
GITHUB_APP_PRIVATE_KEY
GITHUB_APP_SLUG
WEBHOOK_BASE_URL

# Recall.ai — meeting bot service
RECALL_API_KEY=
# Svix-style webhook secret (whsec_ prefixed)
RECALL_WEBHOOK_SECRET=

# Google Calendar Integration
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Whisper.cpp transcription server
# Default: http://127.0.0.1:8080 (local dev), http://whisper:8080 (Docker)
WHISPER_URL=http://127.0.0.1:8080